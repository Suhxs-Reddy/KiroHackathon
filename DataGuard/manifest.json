{
  "manifest_version": 3,
  "name": "DataGuard",
  "version": "0.1.0",
  "description": "See what data any website collects, check breach history, and get opt-out steps — in plain language.",
  "permissions": ["activeTab", "storage", "scripting", "tabs", "notifications", "alarms"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DataGuard"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
